{
  "compilerOptions": {
    "target": "es2019",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "declarationDir": "./dist/types",
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "noEmit": false,
    "allowImportingTsExtensions": true
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "tests",
    "dist"
  ]
}
